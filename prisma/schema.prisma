generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Event {
  id        String       @id @default(cuid())
  title     String
  category  String
  date      String
  location  String
  desc      String
  published Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  photos    EventPhoto[]
}

model EventPhoto {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  path      String
  alt       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String
  excerpt   String
  body      String
  img       String
  alt       String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id        String         @id @default(cuid())
  title     String
  tag       String
  desc      String
  img       String
  alt       String
  order     Int            @default(0)
  published Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  photos    ProjectPhoto[]
}

model ProjectPhoto {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  path      String
  alt       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  path      String
  filename  String
  createdAt DateTime @default(now())
}

/// role: "AMBASSADOR" | "PARENT" | "SCHOOL_OWNER" | "TEACHER" (validated in app code — sqlite has no native enum)
model Member {
  id         String   @id @default(cuid())
  name       String
  email      String?
  phone      String?
  role       String
  stage      String?
  schoolName String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// channel: "EMAIL" | "SMS", status: "SENT" | "FAILED"
model Campaign {
  id          String    @id @default(cuid())
  channel     String
  audience    String?
  subject     String?
  body        String
  sentCount   Int       @default(0)
  failedCount Int       @default(0)
  status      String
  createdAt   DateTime  @default(now())
  sentAt      DateTime?
}
